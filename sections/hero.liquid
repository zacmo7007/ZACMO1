<style>
  .hero-section {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background-image: radial-gradient(circle at center, var(--color-background-light) 0%, var(--color-background) 100%);
  }
  .hero-section::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, rgba(255,0,60,0.15) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    padding: 0 2rem;
  }
  .red-text {
    color: var(--color-primary);
  }
  .hero-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-top: 2rem;
  }
</style>

<div class="hero-section">
  <div class="hero-content">
    <h1 class="heading-hero">
      {{ section.settings.heading | default: 'Electric' }} 
      <span class="red-text">{{ section.settings.heading_highlight | default: 'Style' }}</span>
    </h1>
    <p class="text-body" style="margin-top: 1rem;">
      {{ section.settings.subheading | default: 'Experience the future of streetwear. Premium quality, futuristic design, zero compromises.' }}
    </p>
    <div class="hero-actions">
      <a href="/collections/all" class="btn-primary">Shop Now</a>
      <a href="/pages/custom-designer" class="btn-secondary">Custom Designer</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Electric"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Highlighted Word",
      "default": "Style"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Experience the future of streetwear. Premium quality, futuristic design, zero compromises."
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
