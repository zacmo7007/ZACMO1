<style>
  .custom-designer {
    padding: 120px 2rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .designer-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-top: 3rem;
  }
  .canvas-wrapper {
    background-color: var(--color-background-light);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    display: flex;
    justify-content: center;
    align-items: center;
    aspect-ratio: 1;
  }
  .designer-controls {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 2.5rem;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .control-group label {
    display: block;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  .color-options {
    display: flex;
    gap: 1rem;
  }
  .color-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
  }
  .color-btn.active {
    border-color: var(--color-primary);
    box-shadow: 0 0 10px var(--color-primary);
  }
  .text-input {
    width: 100%;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    color: #fff;
    font-family: inherit;
    font-size: 1.1rem;
  }
</style>

<div class="custom-designer">
  <div style="text-align:center;">
    <h1 class="heading-section">Custom <span style="color:var(--color-primary)">Studio</span></h1>
    <p class="text-body">Design your own premium ZACMO piece.</p>
  </div>

  <div class="designer-layout">
    <div class="canvas-wrapper">
      <canvas id="tshirtCanvas" width="400" height="400" style="max-width:100%;"></canvas>
    </div>

    <div class="designer-controls">
      <div class="control-group">
        <label>Garment Color</label>
        <div class="color-options" id="garmentColors">
          <button class="color-btn active" style="background:#050505" data-color="#050505"></button>
          <button class="color-btn" style="background:#ffffff; border:1px solid #ccc;" data-color="#ffffff"></button>
        </div>
      </div>

      <div class="control-group">
        <label>Custom Text</label>
        <input type="text" id="customText" class="text-input" value="ZACMO" maxlength="15">
      </div>

      <div class="control-group">
        <label>Text Color</label>
        <div class="color-options" id="textColors">
          <button class="color-btn active" style="background:#ff003c" data-color="#ff003c"></button>
          <button class="color-btn" style="background:#ffffff; border:1px solid #ccc;" data-color="#ffffff"></button>
          <button class="color-btn" style="background:#050505; border:1px solid #ccc;" data-color="#050505"></button>
        </div>
      </div>

      <button id="addCustomToCart" class="btn-primary" style="margin-top:1rem; width:100%;">
        Add Design to Cart ($85.00)
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const canvas = document.getElementById('tshirtCanvas');
    const ctx = canvas.getContext('2d');
    
    let state = {
      text: 'ZACMO',
      garmentColor: '#050505',
      textColor: '#ff003c'
    };

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      
      // Draw Garment
      ctx.fillStyle = state.garmentColor;
      ctx.beginPath();
      ctx.moveTo(100, 50); ctx.lineTo(150, 100); ctx.lineTo(130, 120);
      ctx.lineTo(110, 100); ctx.lineTo(110, 350); ctx.lineTo(290, 350);
      ctx.lineTo(290, 100); ctx.lineTo(270, 120); ctx.lineTo(250, 100);
      ctx.lineTo(300, 50); ctx.lineTo(250, 20); ctx.lineTo(230, 40);
      ctx.quadraticCurveTo(200, 70, 170, 40); ctx.lineTo(150, 20);
      ctx.closePath();
      ctx.fill();

      // Shading
      const gradient = ctx.createLinearGradient(100, 0, 300, 0);
      gradient.addColorStop(0, 'rgba(255,255,255,0.1)');
      gradient.addColorStop(1, 'rgba(0,0,0,0.4)');
      ctx.fillStyle = gradient;
      ctx.fill();

      // Draw Text
      ctx.font = '900 40px "Outfit", sans-serif';
      ctx.fillStyle = state.textColor;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      
      if (state.textColor === '#ff003c') {
        ctx.shadowColor = 'rgba(255, 0, 60, 0.8)';
        ctx.shadowBlur = 15;
      }
      ctx.fillText(state.text || 'Your Text', 200, 150);
      ctx.shadowBlur = 0;
    }

    draw();

    document.getElementById('customText').addEventListener('input', (e) => {
      state.text = e.target.value;
      draw();
    });

    document.querySelectorAll('#garmentColors .color-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        document.querySelectorAll('#garmentColors .color-btn').forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        state.garmentColor = e.target.dataset.color;
        draw();
      });
    });

    document.querySelectorAll('#textColors .color-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        document.querySelectorAll('#textColors .color-btn').forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        state.textColor = e.target.dataset.color;
        draw();
      });
    });

    document.getElementById('addCustomToCart').addEventListener('click', () => {
      // In a real Shopify scenario, you'd generate the image via toDataURL
      // and attach it as a Line Item Property to a base dummy product using AJAX cart.
      const image = canvas.toDataURL('image/png');
      alert('Custom design added to cart! (This integrates with Shopify AJAX Cart via Line Item Properties)');
    });
  });
</script>

{% schema %}
{
  "name": "Custom Designer",
  "settings": []
}
{% endschema %}
