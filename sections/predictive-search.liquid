{%- if predictive_search.performed -%}
  <div id="predictive-search-results" class="predictive-search-dropdown">
    {%- if predictive_search.resources.products.size > 0 -%}
      <h3 id="predictive-search-products" class="predictive-search-title">Products</h3>
      <ul role="listbox" aria-labelledby="predictive-search-products" class="predictive-search-list">
        {%- for product in predictive_search.resources.products -%}
          <li id="predictive-search-option-{{ forloop.index }}" class="predictive-search-item" role="option" aria-selected="false">
            <a href="{{ product.url }}" class="predictive-search-item-link">
              {%- if product.featured_media != blank -%}
                <img class="predictive-search-image" src="{{ product.featured_media | img_url: '100x' }}" alt="{{ product.featured_media.alt | escape }}">
              {%- endif -%}
              <div class="predictive-search-item-content">
                <span class="predictive-search-item-heading">{{ product.title }}</span>
                <span class="predictive-search-item-price">{{ product.price | money }}</span>
              </div>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
    
    <button class="predictive-search-submit" tabindex="-1">
      Search for "{{ predictive_search.terms }}"
    </button>
  </div>
{%- endif -%}

<style>
  .predictive-search-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: var(--color-background-light);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0 0 8px 8px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
    z-index: 1000;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .predictive-search-title {
    font-size: 0.9rem;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 700;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    padding-bottom: 0.5rem;
  }
  .predictive-search-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .predictive-search-item-link {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding: 0.5rem;
    border-radius: 4px;
    transition: background var(--transition-fast);
  }
  .predictive-search-item-link:hover {
    background: rgba(255,255,255,0.05);
  }
  .predictive-search-image {
    width: 50px;
    height: 50px;
    object-fit: cover;
    border-radius: 4px;
  }
  .predictive-search-item-content {
    display: flex;
    flex-direction: column;
  }
  .predictive-search-item-heading {
    font-weight: 700;
  }
  .predictive-search-item-price {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .predictive-search-submit {
    padding: 1rem;
    background: var(--color-primary);
    color: #fff;
    text-align: center;
    font-weight: 700;
    border-radius: 4px;
    width: 100%;
  }
</style>
