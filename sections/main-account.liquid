<style>
  .account-page {
    padding: 120px 2rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
    min-height: calc(100vh - 200px);
  }
  .account-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 1rem;
  }
  .logout-btn {
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }
  .logout-btn:hover {
    color: var(--color-primary);
  }
  .account-dashboard {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 4rem;
  }
  .account-main {
    background: var(--color-background-light);
    border-radius: 16px;
    padding: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  .order-history table {
    width: 100%;
    border-collapse: collapse;
  }
  .order-history th, .order-history td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .order-history th {
    color: var(--color-text-muted);
    font-weight: 400;
  }
  @media (max-width: 768px) {
    .account-dashboard {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>

<div class="account-page">
  <div class="account-header">
    <h1 class="heading-section">My <span style="color:var(--color-primary)">Account</span></h1>
    <a href="{{ routes.account_logout_url }}" class="logout-btn">Sign Out</a>
  </div>

  <div class="account-dashboard">
    <aside class="account-sidebar">
      <h2 style="font-size:1.5rem; margin-bottom:1rem;">Account Details</h2>
      <p style="color:var(--color-text-muted); margin-bottom:0.5rem;">{{ customer.name }}</p>
      <p style="color:var(--color-text-muted); margin-bottom:1.5rem;">{{ customer.email }}</p>
      
      <a href="{{ routes.account_addresses_url }}" class="btn-secondary" style="font-size:0.9rem; padding: 0.5rem 1rem;">View Addresses ({{ customer.addresses_count }})</a>
    </aside>

    <div class="account-main">
      <h2 style="font-size:1.5rem; margin-bottom:2rem;">Order History</h2>
      
      {% if customer.orders.size > 0 %}
        <div class="order-history" style="overflow-x:auto;">
          <table>
            <thead>
              <tr>
                <th>Order</th>
                <th>Date</th>
                <th>Payment Status</th>
                <th>Fulfillment Status</th>
                <th>Total</th>
              </tr>
            </thead>
            <tbody>
              {% for order in customer.orders %}
                <tr>
                  <td><a href="{{ order.customer_url }}" style="color:var(--color-primary); font-weight:700;">{{ order.name }}</a></td>
                  <td>{{ order.created_at | date: "%b %d, %Y" }}</td>
                  <td>{{ order.financial_status_label }}</td>
                  <td>{{ order.fulfillment_status_label }}</td>
                  <td>{{ order.total_price | money }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% else %}
        <p class="text-body">You haven't placed any orders yet.</p>
        <a href="/collections/all" class="btn-primary" style="margin-top:1.5rem;">Start Shopping</a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer Account",
  "settings": []
}
{% endschema %}
