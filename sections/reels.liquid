<style>
  .reels-section {
    padding: 4rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  .reels-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
  }
  .reels-container {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    padding-bottom: 2rem;
    scrollbar-width: none;
  }
  .reels-container::-webkit-scrollbar {
    display: none;
  }
  .reel-card {
    min-width: 280px;
    max-width: 320px;
    height: 500px;
    flex: 0 0 auto;
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    background-color: var(--color-background-light);
  }
  .reel-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .reel-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 50%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem;
  }
</style>

<div class="reels-section">
  <div class="reels-header">
    <h2 class="heading-section">ZACMO <span style="color: var(--color-primary)">Reels</span></h2>
  </div>
  
  <div class="reels-container">
    {% for block in section.blocks %}
      <div class="reel-card">
        {% if block.settings.video_url != blank %}
          <video class="reel-video" src="{{ block.settings.video_url }}" autoplay loop muted playsinline></video>
        {% else %}
          <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#222;">
            <p>Add MP4 URL in theme editor</p>
          </div>
        {% endif %}
        <div class="reel-overlay">
          <h3 style="font-weight:700; margin-bottom:1rem;">{{ block.settings.title }}</h3>
          {% if block.settings.product != blank %}
            <a href="{{ all_products[block.settings.product].url }}" class="btn-secondary" style="padding: 0.5rem 1rem; font-size: 0.85rem; background:#fff; color:#000; border:none;">Shop Look</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Video Reels",
  "blocks": [
    {
      "type": "reel",
      "name": "Reel",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Video MP4 URL",
          "info": "Upload video to Shopify Files and paste link here."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Electric Hoodie Check"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Featured Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video Reels",
      "blocks": [
        { "type": "reel" },
        { "type": "reel" }
      ]
    }
  ]
}
{% endschema %}
